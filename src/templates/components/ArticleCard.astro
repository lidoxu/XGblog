---
import type { Post } from '../../features/core/posts';
import { getPostCover, getPostPath } from '../../features/core/posts';
import PostMeta from './PostMeta.astro';

interface Props {
  post: Post;
  index?: number;
}

const { post, index = 0 } = Astro.props;
const cover = getPostCover(post);
const href = getPostPath(post);
const serial = String(index + 1).padStart(2, '0');
---

<article class="article-card" data-index={serial}>
  <a class="card-cover" href={href} aria-label={post.data.title}>
    <img src={cover} alt={`${post.data.title} 封面图`} loading="lazy" />
  </a>
  <div class="card-body">
    <div class="card-title-row">
      {post.data.top > 0 && <span class="pin-label">置顶</span>}
      <h2><a href={href}>{post.data.title}</a></h2>
    </div>
    <p>{post.data.description}</p>
    <PostMeta date={post.data.date} categories={post.data.categories} tags={post.data.tags} compact />
  </div>
</article>
