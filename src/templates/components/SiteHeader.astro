---
import { menuData } from '../../features/core/data';
import { getSite } from '../../features/core/seo';

interface Props {
  currentPath: string;
}

const site = getSite();
const navItems = menuData;
const { currentPath } = Astro.props;

const normalizeTarget = (target?: string | null) => (target === 'blank' || target === '_blank' ? '_blank' : undefined);
---

<header class="site-header" data-site-header>
  <div class="container header-inner">
    <a class="brand" href="/" aria-label={`${site.title} 首页`}>
      <img src={site.logo} alt={`${site.title} logo`} width="44" height="44" />
      <strong>{site.title}</strong>
    </a>
    <nav class="top-nav" id="site-nav" aria-label="站点导航" data-site-nav hidden>
      {navItems.map((item, index) => {
        const hasChildren = item.children && item.children.length > 0;
        const itemTarget = normalizeTarget(item.target);
        const itemRel = itemTarget ? 'noopener noreferrer' : undefined;
        const hasActiveChild = item.children?.some((child) => currentPath === child.href || (child.href !== '/' && currentPath.startsWith(child.href))) ?? false;
        const selfActive =
          currentPath === item.href ||
          (item.href !== '/' && currentPath.startsWith(item.href));
        const active = selfActive || hasActiveChild;
        const submenuId = `submenu-${index}`;

        return (
          <div class:list={['nav-item', { active, 'has-children': hasChildren, 'has-active-child': hasActiveChild }]}>
            <a href={item.href} target={itemTarget} rel={itemRel} class:list={['nav-link', { active: selfActive && !hasActiveChild }]}>
              {item.label}
            </a>
            {hasChildren && (
              <>
                <button
                  class="submenu-toggle"
                  type="button"
                  aria-label={`展开${item.label}子菜单`}
                  aria-controls={submenuId}
                  aria-expanded="false"
                  data-submenu-toggle
                >
                  <span aria-hidden="true"></span>
                </button>
                <div class="submenu" id={submenuId} data-submenu>
                  {item.children!.map((child) => {
                    const childTarget = normalizeTarget(child.target);
                    const childRel = childTarget ? 'noopener noreferrer' : undefined;
                    return (
                      <a href={child.href} target={childTarget} rel={childRel} class:list={['submenu-link', { active: currentPath === child.href || (child.href !== '/' && currentPath.startsWith(child.href)) }]}>
                        {child.label}
                      </a>
                    );
                  })}
                </div>
              </>
            )}
          </div>
        );
      })}
    </nav>
    <div class="header-actions">
      <button class="nav-toggle" type="button" aria-label="打开导航菜单" aria-controls="site-nav" aria-expanded="false" data-nav-toggle>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
      <button class="theme-toggle" type="button" aria-label="切换深浅色主题" data-theme-toggle>◐</button>
    </div>
  </div>
</header>

<script>
  const header = document.querySelector<HTMLElement>('[data-site-header]');
  const nav = header?.querySelector<HTMLElement>('[data-site-nav]');
  const navToggle = header?.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const themeToggle = header?.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const submenuToggles = Array.from(header?.querySelectorAll<HTMLButtonElement>('[data-submenu-toggle]') ?? []);
  const media = window.matchMedia('(prefers-color-scheme: dark)');
  const mobileNav = window.matchMedia('(max-width: 720px)');

  const getStoredTheme = () => {
    try {
      const theme = localStorage.getItem('theme');
      return theme === 'light' || theme === 'dark' ? theme : null;
    } catch {
      return null;
    }
  };

  const getEffectiveTheme = () => document.documentElement.dataset.theme || (media.matches ? 'dark' : 'light');

  const closeSubmenus = () => {
    submenuToggles.forEach((button) => {
      button.setAttribute('aria-expanded', 'false');
      button.closest('.nav-item')?.classList.remove('is-submenu-open');
    });
  };

  const closeNav = () => {
    if (!nav || !navToggle) return;
    nav.classList.remove('is-open');
    nav.hidden = mobileNav.matches;
    navToggle.setAttribute('aria-expanded', 'false');
    header?.setAttribute('data-nav-open', 'false');
    closeSubmenus();
  };

  const syncNav = () => {
    if (!nav || !navToggle) return;
    if (mobileNav.matches) {
      const isOpen = nav.classList.contains('is-open');
      nav.hidden = !isOpen;
      navToggle.setAttribute('aria-expanded', String(isOpen));
      header?.setAttribute('data-nav-open', String(isOpen));
      if (!isOpen) closeSubmenus();
      return;
    }

    nav.hidden = false;
    nav.classList.remove('is-open');
    navToggle.setAttribute('aria-expanded', 'false');
    header?.setAttribute('data-nav-open', 'false');
    closeSubmenus();
  };

  const syncThemeToggle = () => {
    if (!themeToggle) return;
    const theme = getEffectiveTheme();
    themeToggle.textContent = theme === 'dark' ? '☀' : '◐';
    themeToggle.setAttribute('aria-label', theme === 'dark' ? '切换到浅色主题' : '切换到深色主题');
    themeToggle.setAttribute('title', theme === 'dark' ? '切换到浅色主题' : '切换到深色主题');
  };

  syncThemeToggle();
  syncNav();

  media.addEventListener('change', () => {
    if (!getStoredTheme()) {
      document.documentElement.removeAttribute('data-theme');
      syncThemeToggle();
      window.dispatchEvent(new CustomEvent('xg-theme-change'));
    }
  });

  mobileNav.addEventListener('change', syncNav);

  document.addEventListener('click', (event) => {
    if (!mobileNav.matches || !header || header.contains(event.target as Node)) {
      return;
    }
    closeNav();
  });

  nav?.addEventListener('click', (event) => {
    if (mobileNav.matches && event.target === nav) {
      closeNav();
    }
  });

  nav?.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (mobileNav.matches) {
        closeNav();
      }
    });
  });

  submenuToggles.forEach((button) => {
    button.addEventListener('click', () => {
      if (!mobileNav.matches) return;
      const item = button.closest('.nav-item');
      const isOpen = button.getAttribute('aria-expanded') === 'true';
      button.setAttribute('aria-expanded', String(!isOpen));
      item?.classList.toggle('is-submenu-open', !isOpen);
    });
  });

  navToggle?.addEventListener('click', () => {
    if (!nav) return;
    const nextOpen = !nav.classList.contains('is-open');
    nav.classList.toggle('is-open', nextOpen);
    nav.hidden = mobileNav.matches ? !nextOpen : false;
    navToggle.setAttribute('aria-expanded', String(nextOpen));
    header?.setAttribute('data-nav-open', String(nextOpen));
    if (!nextOpen) closeSubmenus();
  });

  themeToggle?.addEventListener('click', () => {
    const next = getEffectiveTheme() === 'dark' ? 'light' : 'dark';
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem('theme', next);
    } catch {
      // The visual switch still works for the current page.
    }
    syncThemeToggle();
    window.dispatchEvent(new CustomEvent('xg-theme-change'));
  });
</script>
