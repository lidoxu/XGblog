<pagefind-modal data-pagefind-modal reset-on-close></pagefind-modal>

<script>
  type PagefindModalElement = HTMLElement & {
    open?: () => void;
  };

  const searchModal = document.querySelector<PagefindModalElement>('[data-pagefind-modal]');
  const searchOpenButtons = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-search-open]'));
  const colorScheme = window.matchMedia('(prefers-color-scheme: dark)');

  let searchReady = false;
  let searchLoading: Promise<boolean> | undefined;

  function syncPagefindTheme() {
    if (!searchModal) return;

    const theme = document.documentElement.dataset.theme;
    const isDark = theme === 'dark' || (!theme && colorScheme.matches);

    if (isDark) {
      searchModal.setAttribute('data-pf-theme', 'dark');
    } else {
      searchModal.removeAttribute('data-pf-theme');
    }
  }

  function loadScript(src: string) {
    return new Promise<boolean>((resolve) => {
      const existing = document.querySelector<HTMLScriptElement>(`script[src="${src}"]`);

      if (existing) {
        resolve(true);
        return;
      }

      const script = document.createElement('script');
      script.src = src;
      script.defer = true;
      script.onload = () => resolve(true);
      script.onerror = () => resolve(false);
      document.head.append(script);
    });
  }

  async function loadSearch() {
    if (searchReady) return true;

    if (!searchLoading) {
      searchLoading = (async () => {
        const stylesheetHref = '/pagefind/pagefind-component-ui.css';
        const hasStylesheet = document.querySelector(`link[href="${stylesheetHref}"]`);

        if (!hasStylesheet) {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = stylesheetHref;
          document.head.append(link);
        }

        const loaded = await loadScript('/pagefind/pagefind-component-ui.js');

        if (!loaded || !searchModal) {
          return false;
        }

        await customElements.whenDefined('pagefind-modal');

        searchReady = true;
        return true;
      })();
    }

    return searchLoading;
  }

  async function openSearch() {
    const loaded = await loadSearch();

    if (loaded && typeof searchModal?.open === 'function') {
      searchModal.open();
    }
  }

  searchOpenButtons.forEach((button) => {
    button.addEventListener('click', openSearch);
  });

  syncPagefindTheme();
  window.addEventListener('xg-theme-change', syncPagefindTheme);
  colorScheme.addEventListener('change', syncPagefindTheme);

  document.addEventListener('keydown', (event) => {
    if ((event.ctrlKey || event.metaKey) && event.key.toLowerCase() === 'k') {
      event.preventDefault();
      openSearch();
    }
  });
</script>
