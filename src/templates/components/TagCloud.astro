---
import type { Post } from '../../features/core/posts';
import { getAllTags } from '../../features/core/taxonomy';

interface Props {
  counts: Map<string, number>;
  posts: Post[];
  limit?: number;
}

const { counts, posts, limit = 20 } = Astro.props;
const tags = await getAllTags(posts);
const sorted = [...tags].sort((a, b) => {
  const countDiff = (counts.get(b.slug) ?? 0) - (counts.get(a.slug) ?? 0);
  return countDiff || a.name.localeCompare(b.name, 'zh-CN');
});
const visible = sorted.slice(0, limit);
---

<section class="sidebar-card tag-card" aria-labelledby="tag-title">
  <div class="section-heading">
    <h2 id="tag-title">标签</h2>
    <a class="more-link" href="/tags">更多</a>
  </div>
  <div class="tag-cloud">
    {visible.map((tag) => (
      <a href={`/tags/${tag.slug}`}>#{tag.name}<small>{counts.get(tag.slug) ?? 0}</small></a>
    ))}
  </div>
</section>
