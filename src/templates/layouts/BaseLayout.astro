---
import SeoHead from '../components/SeoHead.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getSite } from '../../features/core/seo';
import '../styles/global.css';

interface Props {
  title?: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
}

const { title, description, canonical, image, type, publishedTime } = Astro.props;
const site = getSite();
---

<!doctype html>
<html lang="zh-CN" style={`--theme-accent: ${site.theme.accent};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>
      (() => {
        try {
          const theme = localStorage.getItem('theme');
          if (theme === 'light' || theme === 'dark') {
            document.documentElement.dataset.theme = theme;
          }
        } catch {
          // Keep the system preference when storage is unavailable.
        }
      })();
    </script>
    <SeoHead title={title} description={description} canonical={canonical} image={image} type={type} publishedTime={publishedTime} />
  </head>
  <body>
    <SiteHeader currentPath={Astro.url.pathname} />
    <main>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
