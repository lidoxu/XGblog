---
import ArticleList from '../templates/components/ArticleList.astro';
import Sidebar from '../templates/components/Sidebar.astro';
import BaseLayout from '../templates/layouts/BaseLayout.astro';
import { getAllPosts } from '../features/core/posts';
import { getSite } from '../features/core/seo';

const posts = await getAllPosts();
const site = getSite();
---

<BaseLayout description={site.description}>
  <div class="container page-grid">
    <section class="main-column" aria-labelledby="latest-title">
      <div class="section-heading large">
        <h1 id="latest-title">最新文章</h1>
      </div>
      <ArticleList posts={posts} />
    </section>
    <Sidebar posts={posts} />
  </div>
</BaseLayout>
