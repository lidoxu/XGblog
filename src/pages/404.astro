---
import BaseLayout from '../templates/layouts/BaseLayout.astro';

Astro.response.status = 404;
---

<BaseLayout title="页面未找到" description="页面不存在或已经移动。">
  <section class="container narrow error-page" aria-labelledby="error-title">
    <p class="error-code">404</p>
    <h1 id="error-title">页面没找到</h1>
    <p class="error-copy">没有找到对应内容，可能是失效或已经移动。</p>
    <div class="actions">
      <a class="button" href="/">返回首页</a>
      <a class="button ghost" href="/archives">查看归档</a>
    </div>
  </section>
</BaseLayout>
