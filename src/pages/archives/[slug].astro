---
import { render } from 'astro:content';
import PostMeta from '../../templates/components/PostMeta.astro';
import TableOfContents from '../../templates/components/TableOfContents.astro';
import BaseLayout from '../../templates/layouts/BaseLayout.astro';
import { getAllPosts, getPostCover, getPostPath } from '../../features/core/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const cover = getPostCover(post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={getPostPath(post)}
  image={cover}
  type="article"
  publishedTime={post.data.date}
>
  <article class="container article-layout">
    <div class="article-main">
      <header class="article-header">
        <h1>{post.data.title}</h1>
        <PostMeta date={post.data.date} categories={post.data.categories} tags={post.data.tags} />
      </header>
      <div class="prose">
        <Content />
      </div>
    </div>
    <aside class="article-aside">
      <TableOfContents headings={headings} />
    </aside>
  </article>
  <script src="../../features/scripts/toc-active.ts"></script>
  <script src="../../features/scripts/code-copy.ts"></script>
  <script src="../../features/scripts/image-zoom.ts"></script>
</BaseLayout>
