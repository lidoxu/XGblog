---
import BaseLayout from '../templates/layouts/BaseLayout.astro';
import { getSite } from '../features/core/seo';

const site = getSite() as ReturnType<typeof getSite> & {
  author: { name: string; description: string };
};
---

<BaseLayout title="关于" description={`关于${site.title}和作者${site.author.name}。`} canonical="/about">
  <section class="container narrow page-head">
    <h1>关于 {site.title}</h1>
    <p>{site.author.description}</p>
  </section>

  <section class="container narrow prose standalone">
    <p>这里将用于介绍站点方向、作者背景和内容更新范围。首版先作为静态页面预留，后续可以补充更完整的说明。</p>
    <h2>内容范围</h2>
    <ul>
      <li>VPS 优惠、测评和教程。</li>
      <li>Linux、Docker、建站和部署经验。</li>
      <li>AI 工具和效率工作流记录。</li>
    </ul>
  </section>
</BaseLayout>
