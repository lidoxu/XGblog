---
import { allCategories } from '../utils/taxonomy';

interface Props {
  counts: Map<string, number>;
  limit?: number;
}

const { counts, limit = 8 } = Astro.props;
const visible = allCategories.slice(0, limit);
---

<section class="sidebar-card list-card" aria-labelledby="category-title">
  <div class="section-heading">
    <p class="eyebrow">Field Index</p>
    <h2 id="category-title">分类目录</h2>
  </div>
  <ul>
    {visible.map((category) => (
      <li>
        <a href={`/categories/${category.slug}`}>
          <span>{category.name}</span>
          <small>{counts.get(category.slug) ?? 0}</small>
        </a>
      </li>
    ))}
  </ul>
  {allCategories.length > limit && <a class="more-link" href="/categories">更多分类</a>}
</section>
