---
import type { Post } from '../utils/posts';
import { countCategories, countTags } from '../utils/taxonomy';
import AuthorCard from './AuthorCard.astro';
import CategoryList from './CategoryList.astro';
import TagCloud from './TagCloud.astro';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
const categoryCounts = countCategories(posts);
const tagCounts = countTags(posts);
---

<aside class="sidebar" aria-label="博客侧边栏">
  <AuthorCard />
  <CategoryList counts={categoryCounts} />
  <TagCloud counts={tagCounts} />
</aside>
