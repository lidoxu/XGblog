---
import BaseLayout from '../layouts/BaseLayout.astro';
import { linkData } from '../utils/data';

const allLinks = linkData;
---

<BaseLayout title="友链" description="小鸽志友情链接和常用资源。" canonical="/links">
  <section class="container narrow page-head">
    <p class="eyebrow">Links</p>
    <h1>友链与资源</h1>
    <p>一些相关站点和常用技术资源。</p>
  </section>

  <section class="container taxonomy-grid">
    {allLinks.map((link) => (
      <a class="taxonomy-card" href={link.url} target="_blank" rel="noopener noreferrer">
        <span>External</span>
        <h2>{link.name}</h2>
        <p>{link.description}</p>
      </a>
    ))}
  </section>
</BaseLayout>
