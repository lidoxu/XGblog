---
import { render } from 'astro:content';
import PostMeta from '../../components/PostMeta.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getPostPath } from '../../utils/posts';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const cover = post.data.cover ?? '/assets/default-cover.svg';
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonical={getPostPath(post)}
  image={cover}
  type="article"
  publishedTime={post.data.date}
>
  <article class="container article-layout">
    <div class="article-main">
      <header class="article-header">
        <p class="eyebrow">Article</p>
        <h1>{post.data.title}</h1>
        <p class="article-description">{post.data.description}</p>
        <PostMeta date={post.data.date} categories={post.data.categories} tags={post.data.tags} />
        <img class="article-cover" src={cover} alt={`${post.data.title} 封面图`} />
      </header>
      <div class="prose">
        <Content />
      </div>
    </div>
    <aside class="article-aside">
      <TableOfContents headings={headings} />
    </aside>
  </article>
  <script src="../../scripts/code-copy.ts"></script>
  <script src="../../scripts/image-zoom.ts"></script>
</BaseLayout>
