---
import ArticleList from '../components/ArticleList.astro';
import Sidebar from '../components/Sidebar.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllPosts } from '../utils/posts';
import { getSite } from '../utils/seo';

const posts = await getAllPosts();
const site = getSite();
---

<BaseLayout description={site.description}>
  <section class="hero container">
    <p class="eyebrow">XIAOGE JOURNAL</p>
    <h1>把 VPS、建站和工具经验整理成可长期维护的静态内容。</h1>
    <p>{site.description}</p>
  </section>

  <div class="container page-grid">
    <section class="main-column" aria-labelledby="latest-title">
      <div class="section-heading large">
        <p class="eyebrow">Latest Notes</p>
        <h2 id="latest-title">最新文章</h2>
      </div>
      <ArticleList posts={posts} />
    </section>
    <Sidebar posts={posts} />
  </div>
</BaseLayout>
