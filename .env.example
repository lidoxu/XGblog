# 站点基础信息
# 优先级：系统/部署环境变量 > 根目录 .env > blog/data/*.yaml > blog/data/example/*.yaml
BLOG_TITLE="示例博客"
BLOG_SUBTITLE="记录与分享"
BLOG_DESCRIPTION="这里填写站点描述，用于首页和 SEO。"
BLOG_URL="https://example.com"
BLOG_LOGO="/default-logo.svg"
BLOG_DARK_LOGO="/default-logo.svg"
BLOG_SHOW_TITLE="true"

# 主题设置
THEME_COLOR="#6aa6c8"

# 博主信息
BLOG_AUTHOR="博主昵称"
BLOG_AVATAR="/user.jpg"
BLOG_BIO="这里填写博主简介。"
